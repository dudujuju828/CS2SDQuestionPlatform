---
import Layout from "../layouts/Layout.astro";
import { loadAllTopics } from "../lib/questions";

const topics = await loadAllTopics();
---

<Layout title="CS2SD Quiz Platform">
  <main class="home">
    <header class="home-header">
      <h1>CS2SD Quiz Platform</h1>
      <p>Software Systems Design — Multiple Choice Questions</p>
    </header>

    <section class="topics-grid">
      {topics.map(({ slug, data }) => (
        <a href={`/quiz/${slug}`} class="topic-card">
          <h2>{data.topic}</h2>
          <div class="topic-meta">
            <span class={`badge badge-${data.difficulty}`}>{data.difficulty}</span>
            <span class="q-count">{data.questions.length} questions</span>
          </div>
        </a>
      ))}
    </section>

    {topics.length === 0 && (
      <p class="empty">No quizzes found. Add JSON files to the <code>questions/</code> directory and rebuild.</p>
    )}
  </main>
</Layout>

<style>
  .home {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .home-header {
    margin-bottom: 2.5rem;
  }

  .home-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .home-header p {
    color: #6b7280;
    font-size: 1.0625rem;
  }

  .topics-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .topic-card {
    display: block;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    transition: border-color 0.15s, box-shadow 0.15s;
    color: inherit;
    text-decoration: none;
  }

  .topic-card:hover {
    border-color: #2563eb;
    box-shadow: 0 1px 4px rgba(37, 99, 235, 0.1);
    text-decoration: none;
  }

  .topic-card h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .topic-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.875rem;
    color: #6b7280;
  }

  .badge {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-beginner {
    background: #d1fae5;
    color: #065f46;
  }

  .badge-intermediate {
    background: #dbeafe;
    color: #1e40af;
  }

  .badge-advanced {
    background: #fce7f3;
    color: #9d174d;
  }

  .empty {
    color: #9ca3af;
    font-size: 0.9375rem;
  }

  .empty code {
    background: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }
</style>
