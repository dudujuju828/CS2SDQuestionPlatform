---
import type { Question } from "../lib/questions";

interface Props {
  questions: Question[];
  topic: string;
  difficulty: string;
}

const { questions, topic, difficulty } = Astro.props;
---

<div class="quiz-container" data-questions={JSON.stringify(questions)}>
  <header class="quiz-header">
    <a href="/" class="back-link">&larr; All Topics</a>
    <h1>{topic}</h1>
    <div class="quiz-meta">
      <span class={`badge badge-${difficulty}`}>{difficulty}</span>
      <span class="question-count">{questions.length} questions</span>
    </div>
  </header>

  <div class="score-bar">
    <span class="score-text">Score: <strong id="score-current">0</strong> / <strong id="score-total">{questions.length}</strong></span>
    <div class="progress-track">
      <div class="progress-fill" id="progress-fill"></div>
    </div>
    <span class="answered-text" id="answered-text">0 answered</span>
  </div>

  <ol class="questions-list" id="questions-list">
    {questions.map((q, i) => (
      <li class="question-card" id={`card-${q.id}`} data-id={q.id}>
        <div class="question-number">Question {i + 1}</div>
        <p class="stem">{q.stem}</p>
        <div class="options" data-correct={q.correct}>
          {Object.entries(q.options).map(([key, text]) => (
            <button
              class="option-btn"
              data-key={key}
              type="button"
            >
              <span class="option-key">{key}</span>
              <span class="option-text">{text}</span>
            </button>
          ))}
        </div>
        <div class="feedback" hidden>
          <div class="feedback-result"></div>
          <div class="rationale-section">
            <h4>Correct answer rationale</h4>
            <p class="rationale-correct">{q.rationale}</p>
          </div>
          <div class="distractor-section">
            <h4>Why the other options are wrong</h4>
            <div class="distractor-list">
              {Object.entries(q.distractorRationale).map(([key, text]) => (
                <div class="distractor-item">
                  <span class="distractor-key">{key}:</span>
                  <span>{text}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </li>
    ))}
  </ol>

  <div class="quiz-complete" id="quiz-complete" hidden>
    <h2>Quiz Complete</h2>
    <p class="final-score">
      You scored <strong id="final-score-value">0</strong> out of <strong>{questions.length}</strong>
    </p>
    <p class="final-percent" id="final-percent"></p>
    <button class="retry-btn" id="retry-btn" type="button">Retry Quiz</button>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector<HTMLDivElement>(".quiz-container");
    if (!container) return;

    let score = 0;
    let answered = 0;
    const total = container.querySelectorAll(".question-card").length;

    function updateScore() {
      document.getElementById("score-current")!.textContent = String(score);
      document.getElementById("answered-text")!.textContent = `${answered} answered`;
      const fill = document.getElementById("progress-fill") as HTMLDivElement;
      fill.style.width = `${(answered / total) * 100}%`;
    }

    container.querySelectorAll(".question-card").forEach((card) => {
      const optionsDiv = card.querySelector<HTMLDivElement>(".options")!;
      const correct = optionsDiv.dataset.correct!;
      const feedback = card.querySelector<HTMLDivElement>(".feedback")!;
      const resultDiv = feedback.querySelector<HTMLDivElement>(".feedback-result")!;
      const buttons = card.querySelectorAll<HTMLButtonElement>(".option-btn");

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          if (optionsDiv.classList.contains("answered")) return;

          const selected = btn.dataset.key!;
          const isCorrect = selected === correct;

          optionsDiv.classList.add("answered");
          btn.classList.add(isCorrect ? "correct" : "incorrect");

          // Highlight the correct answer
          buttons.forEach((b) => {
            if (b.dataset.key === correct) b.classList.add("correct");
            b.disabled = true;
          });

          if (isCorrect) {
            score++;
            resultDiv.textContent = "Correct!";
            resultDiv.className = "feedback-result feedback-correct";
          } else {
            resultDiv.textContent = `Incorrect — the answer is ${correct}.`;
            resultDiv.className = "feedback-result feedback-incorrect";
          }

          feedback.hidden = false;
          answered++;
          updateScore();

          if (answered === total) {
            const complete = document.getElementById("quiz-complete")!;
            complete.hidden = false;
            document.getElementById("final-score-value")!.textContent = String(score);
            const pct = Math.round((score / total) * 100);
            document.getElementById("final-percent")!.textContent = `${pct}%`;
            complete.scrollIntoView({ behavior: "smooth", block: "center" });
          } else {
            feedback.scrollIntoView({ behavior: "smooth", block: "nearest" });
          }
        });
      });
    });

    document.getElementById("retry-btn")?.addEventListener("click", () => {
      score = 0;
      answered = 0;
      updateScore();
      document.getElementById("quiz-complete")!.hidden = true;

      container.querySelectorAll(".question-card").forEach((card) => {
        const optionsDiv = card.querySelector<HTMLDivElement>(".options")!;
        optionsDiv.classList.remove("answered");
        card.querySelectorAll<HTMLButtonElement>(".option-btn").forEach((btn) => {
          btn.classList.remove("correct", "incorrect");
          btn.disabled = false;
        });
        card.querySelector<HTMLDivElement>(".feedback")!.hidden = true;
      });

      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  });
</script>

<style>
  .quiz-container {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .quiz-header {
    margin-bottom: 1.5rem;
  }

  .back-link {
    font-size: 0.875rem;
    color: #6b7280;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .back-link:hover {
    color: #2563eb;
  }

  .quiz-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .quiz-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.875rem;
    color: #6b7280;
  }

  .badge {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-beginner {
    background: #d1fae5;
    color: #065f46;
  }

  .badge-intermediate {
    background: #dbeafe;
    color: #1e40af;
  }

  .badge-advanced {
    background: #fce7f3;
    color: #9d174d;
  }

  .score-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .score-text {
    white-space: nowrap;
  }

  .progress-track {
    flex: 1;
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: #2563eb;
    border-radius: 3px;
    transition: width 0.3s ease;
    width: 0%;
  }

  .answered-text {
    white-space: nowrap;
    color: #6b7280;
  }

  .questions-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .question-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .question-number {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
    margin-bottom: 0.5rem;
  }

  .stem {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    color: #1a1a2e;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .option-btn {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    background: #fff;
    cursor: pointer;
    text-align: left;
    font-size: 0.9375rem;
    line-height: 1.5;
    transition: border-color 0.15s, background-color 0.15s;
    font-family: inherit;
    color: #1a1a2e;
  }

  .option-btn:hover:not(:disabled) {
    border-color: #2563eb;
    background: #eff6ff;
  }

  .option-btn:disabled {
    cursor: default;
  }

  .option-btn.correct {
    border-color: #16a34a;
    background: #f0fdf4;
  }

  .option-btn.incorrect {
    border-color: #dc2626;
    background: #fef2f2;
  }

  .option-key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: #f3f4f6;
    font-weight: 600;
    font-size: 0.8125rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .correct .option-key {
    background: #16a34a;
    color: #fff;
  }

  .incorrect .option-key {
    background: #dc2626;
    color: #fff;
  }

  .option-text {
    flex: 1;
  }

  .feedback {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e5e7eb;
  }

  .feedback-result {
    font-weight: 600;
    font-size: 0.9375rem;
    margin-bottom: 1rem;
  }

  .feedback-correct {
    color: #16a34a;
  }

  .feedback-incorrect {
    color: #dc2626;
  }

  .rationale-section,
  .distractor-section {
    margin-bottom: 1rem;
  }

  .rationale-section h4,
  .distractor-section h4 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    margin-bottom: 0.375rem;
  }

  .rationale-correct {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #374151;
  }

  .distractor-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .distractor-item {
    font-size: 0.875rem;
    line-height: 1.5;
    color: #6b7280;
  }

  .distractor-key {
    font-weight: 600;
    color: #374151;
  }

  .quiz-complete {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    margin-top: 2rem;
  }

  .quiz-complete h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .final-score {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .final-percent {
    font-size: 2rem;
    font-weight: 700;
    color: #2563eb;
    margin-bottom: 1.5rem;
  }

  .retry-btn {
    padding: 0.625rem 1.5rem;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
  }

  .retry-btn:hover {
    background: #1d4ed8;
  }
</style>
